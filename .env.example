APP_ENV=development
HOST=127.0.0.1
PORT=8000
DATABASE_URL=sqlite:///./data/paperlight.db
OBJECT_STORAGE_MODE=local
OBJECT_STORAGE_DIR=./data/objects
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=paperlight
S3_REGION=us-east-1
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
SESSION_TTL_HOURS=12
DOCUMENT_RETENTION_DAYS=7
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD_HASH=
OWNER_TOTP_SECRET=
REQUIRE_TOTP=1
COOKIE_SECURE=0
TRUST_PROXY=0
JOB_MODE=eager
REDIS_URL=redis://127.0.0.1:6379/0
DETECTOR_MODE=mock
REWRITE_MODE=mock
# Real detectors remain disabled until their data terms are reviewed and this
# acknowledgement is deliberately changed to 1 on the backend.
DETECTOR_DATA_PROCESSING_ACKNOWLEDGED=0
PANGRAM_API_URL=https://text.external-api.pangram.com
PANGRAM_API_KEY=
PANGRAM_POLL_INTERVAL_SECONDS=0.75
PANGRAM_MAX_POLL_SECONDS=45
COPYLEAKS_API_URL=https://api.copyleaks.com
COPYLEAKS_LOGIN_URL=https://id.copyleaks.com/v3/account/login/api
COPYLEAKS_EMAIL=
COPYLEAKS_API_KEY=
COPYLEAKS_SANDBOX=0
COPYLEAKS_SENSITIVITY=2
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_VALIDATOR_MODEL=deepseek-v4-flash
PROVIDER_TIMEOUT_SECONDS=45
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_BASE_PATH=
