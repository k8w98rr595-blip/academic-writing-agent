APP_ENV=development
HOST=127.0.0.1
PORT=8000
DATABASE_URL=sqlite:///./data/paperlight.db
OBJECT_STORAGE_MODE=local
OBJECT_STORAGE_DIR=./data/objects
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=paperlight
S3_REGION=us-east-1
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
SESSION_TTL_HOURS=12
DOCUMENT_RETENTION_DAYS=7
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD_HASH=
OWNER_TOTP_SECRET=
REQUIRE_TOTP=1
COOKIE_SECURE=0
TRUST_PROXY=0
JOB_MODE=eager
REDIS_URL=redis://127.0.0.1:6379/0
DETECTOR_MODE=mock
REWRITE_MODE=mock
PANGRAM_API_URL=https://api.pangram.com/v1/predict
PANGRAM_API_KEY=
COPYLEAKS_API_URL=https://api.copyleaks.com/v2/writer-detector
COPYLEAKS_ACCESS_TOKEN=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_VALIDATOR_MODEL=deepseek-v4-flash
PROVIDER_TIMEOUT_SECONDS=45
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_BASE_PATH=
